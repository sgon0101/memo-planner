# OS 간 line ending 충돌 방지: 모든 텍스트 파일을 LF로 저장
* text=auto eol=lf

# Windows 전용 스크립트는 CRLF 유지 (cmd가 LF 못 읽음)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 바이너리 파일 명시
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
